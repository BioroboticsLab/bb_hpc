###############################################################################
# Dockerfile-comb-background
# - CUDA-ready NGC base (NGC PyTorch 24.08)
# - Python 3.12 via conda-forge (Miniforge) in conda env "combbg"
# - cell-seg heavy tools (frame_extractor + background_generator) installed from
#   the bbhpc-integration branch (override with --build-arg CELLSEG_REPO_REF=...)
# - Layout matches the docker/k8s runner bash: /opt/conda + `conda activate combbg`
###############################################################################
FROM nvcr.io/nvidia/pytorch:24.08-py3 AS base

ENV DEBIAN_FRONTEND=noninteractive

# OS deps
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
      git ffmpeg wget ca-certificates bzip2 && \
    rm -rf /var/lib/apt/lists/*

# Download & install Miniforge3 (conda-forge’s lightweight installer)
RUN wget --quiet \
      https://github.com/conda-forge/miniforge/releases/latest/download/Miniforge3-Linux-x86_64.sh \
    -O /tmp/miniforge.sh && \
    bash /tmp/miniforge.sh -b -p /opt/conda && \
    rm /tmp/miniforge.sh

# Put conda on the PATH and disable auto-activation of base
ENV PATH="/opt/conda/bin:$PATH" \
    CONDA_AUTO_ACTIVATE_BASE="false"

# Use bash login shell so "conda" and "activate" work naturally
SHELL ["/bin/bash", "-lc"]

# Create conda env with Python 3.12 and pip
RUN set -euo pipefail && \
    conda create -y -n combbg python=3.12 pip && \
    conda clean -a -y

# Make the env default on PATH for subsequent RUNs
ENV CONDA_DEFAULT_ENV=combbg \
    PATH="/opt/conda/envs/combbg/bin:$PATH"

WORKDIR /workspace

# Install Poetry into the conda env and configure it to avoid creating its own venv
RUN set -euo pipefail && \
    pip install --no-cache-dir --upgrade pip setuptools wheel && \
    pip install --no-cache-dir poetry && \
    poetry --version && \
    poetry config virtualenvs.create false

# Clone and install the cell-seg heavy tools (frame extractor + background generator).
# install.py background-generator installs honeybee_segmentor + frame_extractor +
# background_generator (editable) from the heavy_preprocessing/ layout.
# Branch matters: bb_hpc calls BackgroundImageGenerator(..., cams=[cam]), which only
# exists on bbhpc-integration -- a `main` build is missing the cams= argument.
ARG CELLSEG_REPO_URL=https://github.com/BioroboticsLab/honeybee_cell_segmentation_pipeline.git
ARG CELLSEG_REPO_REF=bbhpc-integration
RUN set -euo pipefail && \
    git clone --depth=1 --branch "$CELLSEG_REPO_REF" "$CELLSEG_REPO_URL" honeybee_cell_segmentation_pipeline && \
    cd honeybee_cell_segmentation_pipeline && \
    python install.py background-generator && \
    # Ensure CUDA-enabled Torch in this env (for segmentation-models-pytorch)
    python -m pip install --index-url https://download.pytorch.org/whl/cu126 \
        torch torchvision torchaudio

# Build-time sanity check: torch imports and the bb_hpc-facing API is present
# (cams= proves we built the right branch).
RUN python - <<'PY'
import inspect, sys, torch
from background_generator.background_img_generator import BackgroundImageGenerator as B
sig = inspect.signature(B.__init__)
print('Torch:', torch.__version__)
print('BackgroundImageGenerator.__init__', sig)
assert 'cams' in sig.parameters, "wrong branch: BackgroundImageGenerator has no cams= (need bbhpc-integration)"
sys.exit(0)
PY

# The frame extractor finds ffmpeg on PATH automatically (determine_ffmpeg_bin_path).
# NOTE: the apt ffmpeg may lack NVDEC (hevc_cuvid). For GPU decode supply a
# CUDA-enabled ffmpeg on PATH; otherwise run extraction with software decode
# (decoder=None / --decoder none).
RUN set -euo pipefail && (command -v ffmpeg && echo "ffmpeg available on PATH" || echo "WARNING: ffmpeg not found")

CMD ["/bin/bash"]
